{
  "name": "blog",
  "version": "2.0.0",
  "description": "My Blog",
  "main": "src/js/main.js",
  "contributors": [
    "Sam Richard <snugug@google.com> (https://snugug.com)"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "start": "run-s vite",
    "prebuild": "run-s lint",
    "build": "NODE_ENV=production run-p *:build",
    "test": "run-s build",
    "lint": "run-p *:lint",
    "fix": "run-p *:fix",
    "js:lint": "eslint .",
    "js:fix": "eslint --fix .",
    "css:lint": "stylelint src/sass",
    "css:fix": "stylelint --fix src/sass",
    "prettier:lint": "run-p prettier:*:lint",
    "prettier:fix": "run-p prettier:*:fix",
    "prettier:files:lint": "prettier -c .",
    "prettier:njk:lint": "prettier -c '**/*.njk'",
    "prettier:files:fix": "prettier --write .",
    "prettier:njk:fix": "prettier --write '**/*.njk'",
    "md:lint": "remark -qf .",
    "vite": "vite --host",
    "vite:build": "vite build --emptyOutDir",
    "prepare": "husky install",
    "husky": "husky"
  },
  "devDependencies": {
    "@emmetio/expand-abbreviation": "^0.7.3",
    "autoprefixer": "^10.2.6",
    "better-npm-run": "^0.1.1",
    "breakpoint-sass": "^2.7.1",
    "eslint": "^7.28.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-import": "^2.23.4",
    "eslint-plugin-prettier": "^3.4.0",
    "husky": "^6.0.0",
    "letterform-shades": "^1.0.0",
    "markdown-it": "^12.0.6",
    "markdown-it-abbr": "^1.0.4",
    "markdown-it-anchor": "^7.1.0",
    "markdown-it-attrs": "^4.0.0",
    "markdown-it-container": "^3.0.0",
    "markdown-it-deflist": "^2.1.0",
    "markdown-it-emoji": "^2.0.0",
    "markdown-it-figure": "^0.2.0",
    "markdown-it-footnote": "^3.0.3",
    "markdown-it-header-sections": "^1.0.0",
    "markdown-it-kbd": "^2.2.2",
    "markdown-it-sup": "^1.0.0",
    "markdown-it-video": "^0.6.3",
    "npm-run-all": "^4.1.5",
    "posthtml-minifier": "^0.1.0",
    "prettier": "^2.3.1",
    "prismjs": "^1.23.0",
    "remark": "^13.0.0",
    "remark-cli": "^9.0.0",
    "remark-frontmatter": "^3.0.0",
    "remark-lint": "^8.0.0",
    "remark-lint-heading-increment": "^2.0.1",
    "remark-lint-prohibited-strings": "^2.0.0",
    "remark-preset-lint-recommended": "^5.0.0",
    "sass": "^1.34.1",
    "sass-toolkit": "^2.10.2",
    "stylelint": "^13.13.1",
    "stylelint-config-sass-guidelines": "^8.0.0",
    "stylelint-config-standard": "^22.0.0",
    "uslug": "^1.0.4",
    "vite": "^2.3.7",
    "vite-plugin-eleventy": "0.0.7",
    "vite-plugin-imagemin": "^0.3.2",
    "vite-plugin-img": "0.0.1",
    "vite-plugin-posthtml": "0.0.2",
    "vite-plugin-pwa": "^0.7.3"
  },
  "dependencies": {
    "idb-keyval": "^5.0.6",
    "workbox-cacheable-response": "^6.1.5",
    "workbox-core": "^6.1.5",
    "workbox-expiration": "^6.1.5",
    "workbox-precaching": "^6.1.5",
    "workbox-routing": "^6.1.5",
    "workbox-strategies": "^6.1.5"
  },
  "private": true,
  "volta": {
    "node": "14.17.0"
  }
}
