---
import Layout from '$layouts/Donut.astro';
import Admin from '$components/admin/Admin.svelte';
import schemas from 'virtual:collections';

/**
 * Pre-renders /admin and /admin/{collection} for each known collection.
 * All paths serve the same SPA shell -- client-side Navigation API handles routing.
 */
export function getStaticPaths() {
  const collections = Object.keys(schemas);
  return [
    { params: { path: undefined } },
    ...collections.map((name) => ({ params: { path: name } })),
  ];
}
---

<Layout title="Admin" summary="Content management interface">
  <link
    slot="head"
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=hourglass_arrow_down,hourglass_arrow_up,sort_by_alpha&display=block"
    rel="stylesheet"
  />
  <Admin client:only="svelte" />
</Layout>
